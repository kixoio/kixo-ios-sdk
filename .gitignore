# Swift Package Manager build artifacts (consumers' resolution caches).
.build/
Package.resolved
.swiftpm/

# Xcode user state — never commit. Project files for the test app
# are git-tracked at canonical paths only.
xcuserdata/
*.xcworkspace/
DerivedData/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# macOS metadata
.DS_Store

# Editor scratch
*.swp
.idea/
.vscode/

# Local checksums / scratch (generated by SDK build pipeline upstream
# in kixo-ios-sdk; the resulting XCFramework lives committed at
# Frameworks/KixoSDK.xcframework — but never the .zip / .sha256).
*.xcframework.zip
*.xcframework.zip.sha256
